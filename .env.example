# .env.example
# 使い方:
#   cp .env.example .env
#   nano .env  # 下の値を実値に書き換える
# このファイル (.env.example) はリポジトリにコミットされる。
# 実値が入った .env は .gitignore で除外される。

# いえらぶBB ログイン情報
IELOVE_ID=your_ielove_id_here
IELOVE_PASSWORD=your_ielove_password_here

# Google スプレッドシートID (URLの /d/ と /edit の間)
SPREADSHEET_ID=your_spreadsheet_id_here

# Discord 通知用 Webhook URL (空欄なら通知なし)
# 失敗時のみ Discord に通知される
DISCORD_WEBHOOK_URL=

# 以下は Mac 実行では不要（GitHub Actions 側で使う）
# ITANDI_EMAIL=
# ITANDI_PASSWORD=
# ES_EMAIL=
# ES_PASSWORD=
